{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skillrobust.local/schema/structured_evidence_bundle.schema.json",
  "title": "StructuredEvidenceBundle",
  "type": "object",
  "required": [
    "sample_id",
    "mode",
    "source_package_label",
    "evidence_items",
    "aggregation_features"
  ],
  "properties": {
    "sample_id": {
      "type": "string"
    },
    "mode": {
      "type": "string",
      "enum": ["full_package"]
    },
    "source_package_label": {
      "type": "string",
      "enum": ["benign", "suspicious", "malicious"]
    },
    "evidence_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "evidence_id",
          "path",
          "role",
          "risk_tag",
          "signal_family",
          "severity",
          "explicitness",
          "support_label",
          "span_text",
          "rationale"
        ],
        "properties": {
          "evidence_id": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": ["skill_md", "reference", "script", "repo_context", "asset", "other"]
          },
          "risk_tag": {
            "type": "string",
            "enum": ["T1", "T2", "T3", "T4", "T5", "T6", "T7", "T8"]
          },
          "signal_family": {
            "type": "string",
            "enum": [
              "override",
              "concealment",
              "tool_execution",
              "external_transfer",
              "remote_bootstrap",
              "cover_story",
              "privilege_overreach",
              "description_mismatch"
            ]
          },
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "explicitness": {
            "type": "string",
            "enum": ["surface", "cross_file", "latent"]
          },
          "support_label": {
            "type": "string",
            "enum": ["benign", "suspicious", "malicious"]
          },
          "cross_file_group": {
            "type": ["string", "null"]
          },
          "span_text": {
            "type": "string"
          },
          "rationale": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "aggregation_features": {
      "type": "object",
      "required": [
        "role_counts",
        "tag_counts",
        "has_reference_only_override",
        "has_cover_story_chain",
        "has_hidden_transfer_chain",
        "has_remote_bootstrap_chain",
        "has_cross_file_support",
        "has_simulation_wrappers",
        "recommended_label_floor"
      ],
      "properties": {
        "role_counts": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "tag_counts": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "has_reference_only_override": {
          "type": "boolean"
        },
        "has_cover_story_chain": {
          "type": "boolean"
        },
        "has_hidden_transfer_chain": {
          "type": "boolean"
        },
        "has_remote_bootstrap_chain": {
          "type": "boolean"
        },
        "has_cross_file_support": {
          "type": "boolean"
        },
        "has_simulation_wrappers": {
          "type": "boolean"
        },
        "recommended_label_floor": {
          "type": "string",
          "enum": ["benign", "suspicious", "malicious"]
        },
        "consistency_anchor": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": false
    },
    "meta": {
      "type": "object",
      "properties": {
        "subset": {
          "type": "string",
          "enum": ["clean", "risk", "attack_rewrite"]
        },
        "risk_tags": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["T1", "T2", "T3", "T4", "T5", "T6", "T7", "T8"]
          }
        },
        "signal_counts": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
