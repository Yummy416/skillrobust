# Copy this file to `.env` and edit it for your local machine.

# Repository root. Usually this can be left empty because the shell scripts
# derive it automatically from their own location.
SKILLROBUST_ROOT_DIR=

# Directory that stores local model checkpoints used by vLLM serve scripts.
SKILLROBUST_MODEL_ROOT=

# Host used by remote evaluation scripts and endpoint checks.
SKILLROBUST_SERVER_IP=127.0.0.1

# Optional shared API key. Leave empty if your local endpoint does not require auth.
SKILLROBUST_API_KEY=

# Optional explicit local checkpoint path for the transformers Prompt Guard baseline.
PROMPT_GUARD_MODEL_DIR=
